// PM2 配置文件模板
// 使用方法：
//   1. 复制此文件为 ecosystem.config.js
//   2. 填入你的真实密钥
//   3. 运行 pm2 start ecosystem.config.js
//
// ⚠️ ecosystem.config.js 已加入 .gitignore，切勿提交真实密钥！

module.exports = {
  apps: [
    {
      name: "kedazi-app",
      script: "./server.js",
      cwd: __dirname,                       // 固定工作目录（必须）
      instances: 1,                         // SQLite 单实例防锁死
      exec_mode: "fork",
      autorestart: true,
      watch: false,                         // 生产环境关闭文件监听
      max_memory_restart: "1G",

      // 日志路径
      error_file: "./logs/pm2-error.log",
      out_file: "./logs/pm2-out.log",
      log_date_format: "YYYY-MM-DD HH:mm:ss Z",
      merge_logs: true,

      // 环境变量（填入你的真实密钥）
      env: {
        NODE_ENV: "production",
        PORT: 3000,
        JWT_SECRET: "your-64-char-random-hex-key",
        RESEND_API_KEY: "re_*********",
        TURNSTILE_SITE_KEY: "your-turnstile-site-key",
        TURNSTILE_SECRET_KEY: "your-turnstile-secret-key"
      }
    }
  ]
};
